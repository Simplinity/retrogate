// RetroGate Xcode Build Configuration
// Import this xcconfig in your Xcode project for App Store builds.

// Bundle ID
PRODUCT_BUNDLE_IDENTIFIER = com.brunowernimont.retrogate

// Deployment target
MACOSX_DEPLOYMENT_TARGET = 13.0

// Code signing (change team ID to your own)
// CODE_SIGN_IDENTITY = Apple Distribution
// DEVELOPMENT_TEAM = YOUR_TEAM_ID
CODE_SIGN_STYLE = Automatic

// Hardened Runtime (required for notarization + App Store)
ENABLE_HARDENED_RUNTIME = YES

// App Sandbox (already in entitlements, but also set here)
ENABLE_APP_SANDBOX = YES

// Swift settings
SWIFT_VERSION = 5.9

// Info.plist
INFOPLIST_FILE = Sources/RetroGate/Info.plist
CODE_SIGN_ENTITLEMENTS = Sources/RetroGate/RetroGate.entitlements

// Product settings
PRODUCT_NAME = RetroGate
PRODUCT_MODULE_NAME = RetroGate

// Asset catalog
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon

// Build optimization
SWIFT_OPTIMIZATION_LEVEL[config=Release] = -O
SWIFT_COMPILATION_MODE[config=Release] = wholemodule
